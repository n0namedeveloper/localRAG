# ========================================
# LocalRAG Configuration
# ========================================

# DeepSeek API (via OpenRouter or direct DeepSeek API)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# Or via OpenRouter: https://openrouter.ai/api/v1
DEEPSEEK_MODEL=deepseek-chat

# Embeddings
# Options: "bge-m3" (local), "openai" (requires OPENAI_API_KEY)
EMBEDDING_PROVIDER=bge-m3
OPENAI_API_KEY=sk-your-openai-key  # Only if EMBEDDING_PROVIDER=openai

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=code_chunks

# GitHub (optional, for private repos and higher rate limits)
GITHUB_TOKEN=ghp_your_github_token

# Application
DATA_DIR=./data
GRAMMARS_DIR=./grammars
MAX_CHUNKS_PER_QUERY=15
MAX_GRAPH_HOPS=1
LOG_LEVEL=INFO